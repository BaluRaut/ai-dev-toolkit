# ============================================
# Claude Agent Configuration
# Copy this file to .env and fill in your keys
# ============================================

# --- Anthropic (Claude) API ---
ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- Jira Configuration ---
JIRA_BASE_URL=https://your-company.atlassian.net
JIRA_EMAIL=your-email@company.com
JIRA_API_TOKEN=your-jira-api-token

# --- Figma Configuration ---
FIGMA_ACCESS_TOKEN=your-figma-token

# --- Project Configuration ---
PROJECT_TECH_STACK=React 18, TypeScript, Tailwind CSS, React Query
PROJECT_FOLDER_STRUCTURE=feature-based
OUTPUT_DIR=./output

# ─────────────────────────────────────────────────
# MCP Preset credentials (optional — only needed
# when using the named presets via --mcp <preset>)
# ─────────────────────────────────────────────────

# --mcp github
GITHUB_TOKEN=ghp_your-github-token

# --mcp slack
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_TEAM_ID=T00000000

# --mcp postgres
DATABASE_URL=postgresql://user:password@localhost:5432/mydb

# --mcp search  (Brave Search API)
BRAVE_API_KEY=your-brave-api-key
